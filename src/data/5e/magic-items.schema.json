{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Magic Items Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the magic item"
      },
      "name": {
        "type": "string",
        "description": "Full name of the magic item"
      },
      "description": {
        "type": "string",
        "description": "Description of the magic item"
      },
      "rarity": {
        "type": "string",
        "description": "Rarity of the item (common, uncommon, rare, very rare, legendary)"
      },
      "requiresAttunement": {
        "type": "boolean",
        "description": "Whether the item requires attunement"
      },
      "type": {
        "type": "string",
        "description": "Type of magic item"
      },
      "subtype": {
        "type": "string",
        "description": "Subtype of the magic item"
      },
      "attunement_requirements": {
        "type": "string",
        "description": "Specific attunement requirements"
      },
      "properties": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Properties of the magic item"
      }
    }
  }
}
