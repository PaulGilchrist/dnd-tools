{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rules Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name", "desc"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the rule"
      },
      "name": {
        "type": "string",
        "description": "Full name of the rule"
      },
      "desc": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Description of the rule"
      }
    }
  }
}
