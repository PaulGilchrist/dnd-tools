{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/feats.schema.json",
  "title": "Feats Schema",
  "description": "Schema for D&D-style feats including General Feats, Fighting Style Feats, Origin Feats, and Epic Boon Feats. Captures all feat data from the feats_clean directory.",
  "type": "object",
  "properties": {
    "feats": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feat"
      },
      "minItems": 1
    },
    "fast_crafting_table": {
      "type": "object",
      "description": "Reference table mapping Artisan's Tools to crafted gear items (from the FAST_CRAFTING.md file).",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fastCraftingEntry"
          },
          "minItems": 1
        }
      },
      "required": [
        "entries"
      ]
    }
  },
  "required": [
    "feats",
    "fast_crafting_table"
  ],
  "$defs": {
    "feat": {
      "type": "object",
      "description": "A feat with its name, type, prerequisites, benefits, and metadata.",
      "required": [
        "name",
        "type",
        "description",
        "prerequisites",
        "benefits",
        "ability_score_increase",
        "repeatable",
        "tags"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the feat in PascalCase (e.g., 'Actor', 'Athlete').",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "General Feat",
            "Fighting Style Feat",
            "Origin Feat",
            "Epic Boon Feat"
          ],
          "description": "The classification of the feat."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Full description text of the feat."
        },
        "prerequisites": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "properties": {
                "level": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Minimum character level required."
                },
                "ability_scores": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/abilityScoreRequirement"
                  },
                  "minItems": 1,
                  "description": "Ability score prerequisites."
                },
                "feature": {
                  "type": "string",
                  "enum": [
                    "Fighting Style",
                    "Spellcasting",
                    "Pact Magic",
                    "Spellcasting or Pact Magic"
                  ],
                  "description": "Required class feature prerequisite."
                },
                "armor_training": {
                  "type": "string",
                  "enum": [
                    "Light Armor Training",
                    "Medium Armor Training",
                    "Heavy Armor Training",
                    "Shield Training"
                  ],
                  "description": "Required armor training prerequisite."
                },
                "weapon_training": {
                  "type": "string",
                  "enum": [
                    "Martial weapons"
                  ],
                  "description": "Required weapon training prerequisite."
                }
              },
              "minProperties": 1
            }
          ],
          "description": "Prerequisites for gaining this feat."
        },
        "benefits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/benefit"
          },
          "minItems": 1,
          "description": "List of benefits provided by this feat."
        },
        "ability_score_increase": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "properties": {
                "scores": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/abilityName"
                  },
                  "minItems": 1,
                  "description": "Which ability scores can be increased."
                },
                "amount": {
                  "oneOf": [
                    {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 2
                    },
                    {
                      "type": "string",
                      "enum": [
                        "variable"
                      ]
                    }
                  ],
                  "description": "Amount to increase by."
                },
                "max_value": {
                  "type": "integer",
                  "enum": [
                    20,
                    30
                  ],
                  "description": "Maximum value the ability score can reach."
                }
              },
              "required": [
                "scores",
                "amount",
                "max_value"
              ],
              "additionalProperties": false
            }
          ],
          "description": "Ability score increase provided by this feat."
        },
        "repeatable": {
          "type": "boolean",
          "description": "Whether this feat can be taken multiple times."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Tags describing the feat's theme or category."
        }
      },
      "additionalProperties": false
    },
    "abilityScoreRequirement": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/abilityName"
        },
        "minimum": {
          "type": "integer",
          "minimum": 10,
          "maximum": 20
        }
      },
      "required": [
        "name",
        "minimum"
      ],
      "additionalProperties": false
    },
    "abilityName": {
      "type": "string",
      "enum": [
        "Strength",
        "Dexterity",
        "Constitution",
        "Intelligence",
        "Wisdom",
        "Charisma"
      ],
      "description": "One of the six ability scores."
    },
    "benefit": {
      "type": "object",
      "description": "A single benefit provided by a feat.",
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "The name of the benefit."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Full description of the benefit."
        },
        "type": {
          "type": "string",
          "enum": [
            "ability_score_increase",
            "speed",
            "proficiency",
            "resistance",
            "condition",
            "action",
            "reaction",
            "bonus_action",
            "passive",
            "spell",
            "saving_throw",
            "damage",
            "movement",
            "equipment",
            "utility",
            "other"
          ],
          "description": "Categorization of the benefit type."
        }
      },
      "additionalProperties": false
    },
    "fastCraftingEntry": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string",
          "description": "The Artisan's Tool name."
        },
        "gear": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "List of crafted gear items available with this tool."
        }
      },
      "required": [
        "tool",
        "gear"
      ],
      "additionalProperties": false
    }
  }
}