{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Equipment Schema (2024 Rules)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the equipment"
      },
      "name": {
        "type": "string",
        "description": "Full name of the equipment"
      },
      "equipment_category": {
        "type": "string",
        "description": "Category of equipment"
      },
      "gear_category": {
        "type": "string",
        "description": "Specific gear category"
      },
      "cost": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          }
        }
      },
      "weight": {
        "type": "number",
        "description": "Weight of the equipment"
      },
      "desc": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Description of the equipment"
      },
      "damage": {
        "type": "object",
        "description": "Damage information for weapons"
      },
      "properties": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Weapon properties"
      },
      "quantity": {
        "type": "integer",
        "description": "Quantity included (2024 rules)"
      },
      "group": {
        "type": "string",
        "description": "Equipment group (2024 rules)"
      }
    }
  }
}
