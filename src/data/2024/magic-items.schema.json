{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Magic Items Schema (2024 Rules)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the magic item"
      },
      "name": {
        "type": "string",
        "description": "Full name of the magic item"
      },
      "description": {
        "type": "string",
        "description": "Description of the magic item"
      },
      "rarity": {
        "type": "string",
        "description": "Rarity of the item (common, uncommon, rare, very rare, legendary, artifact)",
        "enum": ["common", "uncommon", "rare", "very rare", "legendary", "artifact"]
      },
      "requiresAttunement": {
        "type": "boolean",
        "description": "Whether the item requires attunement"
      },
      "type": {
        "type": "string",
        "description": "Type of magic item (e.g., Wondrous Item, Rod, Staff, Wand, Weapon, Armor, Scroll, Ring, Amulet)"
      },
      "subtype": {
        "type": "string",
        "description": "Subtype of the magic item (e.g., Light, Medium, Heavy, Shield, Simple, Martial)"
      },
      "attunement_requirements": {
        "type": "string",
        "description": "Specific attunement requirements (e.g., 'by a Sorcerer, Warlock, or Wizard')"
      },
      "properties": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Properties of the magic item"
      },
      "charge_system": {
        "type": "object",
        "description": "Charge system for items with charges (2024 rules)",
        "properties": {
          "total_charges": {
            "type": "number",
            "description": "Maximum number of charges the item has"
          },
          "regain_type": {
            "type": "string",
            "description": "Type of charge regain (e.g., 'daily at dawn', 'roll on 1')"
          },
          "regain_formula": {
            "type": "string",
            "description": "Formula for regaining charges (e.g., '1d6 + 4', '2d8 + 4')"
          },
          "destroy_on_exhaust": {
            "type": "boolean",
            "description": "Whether the item is destroyed when last charge is expended"
          },
          "recovery_on_exhaust": {
            "type": "boolean",
            "description": "Whether the item has a chance to recover charges when last charge is expended"
          }
        }
      },
      "usage_limit": {
        "type": "string",
        "description": "Usage limits for the item (2024 rules)"
      },
      "item_slot": {
        "type": "string",
        "description": "Equipment slot for the item (2024 rules)"
      },
      "spell_casting": {
        "type": "object",
        "description": "Spell casting properties for items that allow spell casting",
        "properties": {
          "save_dc": {
            "type": "number",
            "description": "Spell save DC for the item"
          },
          "attack_bonus": {
            "type": "number",
            "description": "Spell attack bonus for the item"
          },
          "spells": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Name of the spell"
                },
                "charge_cost": {
                  "type": "number",
                  "description": "Number of charges required to cast this spell"
                },
                "level": {
                  "type": "number",
                  "description": "Spell level"
                }
              }
            },
            "description": "List of spells the item can cast with charge costs"
          }
        }
      },
      "damage": {
        "type": "object",
        "description": "Damage properties of the item",
        "properties": {
          "damage_dice": {
            "type": "string",
            "description": "Damage dice (e.g., '1d6', '2d6', '4d6', '16 times charges')"
          },
          "damage_type": {
            "type": "string",
            "description": "Type of damage (e.g., Fire, Cold, Lightning, Necrotic, Force, Thunder, Radiant, Psychic, Slashing, Bludgeoning, Piercing)"
          },
          "extra_damage": {
            "type": "string",
            "description": "Extra damage conditions (e.g., 'extra 2d6 Fire damage on hit')"
          }
        }
      },
      "saving_throws": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "dc": {
              "type": "number",
              "description": "Saving throw DC"
            },
            "ability": {
              "type": "string",
              "description": "Ability used for saving throw (e.g., 'Constitution', 'Dexterity', 'Wisdom', 'Strength', 'Charisma')"
            },
            "effect_on_fail": {
              "type": "string",
              "description": "Effect on failed save"
            },
            "effect_on_success": {
              "type": "string",
              "description": "Effect on successful save"
            }
          }
        },
        "description": "Saving throws associated with the item"
      },
      "conditions": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Conditions the item can impose or protect against (e.g., 'Paralyzed', 'Frightened', 'Restrained', 'Stunned', 'Deafened', 'Prone')"
      },
      "resistances": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Resistances granted by the item (e.g., 'Fire damage', 'Necrotic damage')"
      },
      "immunities": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Immunities granted by the item (e.g., 'Poison damage', 'Psychic damage')"
      },
      "bonuses": {
        "type": "object",
        "description": "Bonuses granted by the item",
        "properties": {
          "attack_bonus": {
            "type": "number",
            "description": "Bonus to attack rolls"
          },
          "damage_bonus": {
            "type": "number",
            "description": "Bonus to damage rolls"
          },
          "ac_bonus": {
            "type": "number",
            "description": "Bonus to Armor Class"
          },
          "saving_throw_bonus": {
            "type": "number",
            "description": "Bonus to saving throws"
          },
          "ability_check_bonus": {
            "type": "number",
            "description": "Bonus to ability checks"
          },
          "ability_score_increase": {
            "type": "object",
            "description": "Increase to ability scores",
            "properties": {
              "ability": {
                "type": "string",
                "description": "Ability score name (e.g., 'Strength', 'Intelligence', 'Charisma', 'Wisdom')"
              },
              "amount": {
                "type": "number",
                "description": "Amount to increase by"
              },
              "maximum": {
                "type": "number",
                "description": "Maximum value for the ability score"
              }
            }
          }
        }
      },
      "advantage_disadvantage": {
        "type": "object",
        "description": "Advantage or Disadvantage granted by the item",
        "properties": {
          "advantage_on": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Things the item grants Advantage on (e.g., 'Initiative rolls', 'Perception checks')"
          },
          "disadvantage_on": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Things the item grants Disadvantage on"
          }
        }
      },
      "action_types": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Action types required to use item properties (e.g., 'Magic action', 'Bonus Action', 'Reaction', 'Utilize action')"
      },
      "range": {
        "type": "object",
        "description": "Range properties of the item",
        "properties": {
          "melee_range": {
            "type": "number",
            "description": "Melee range in feet"
          },
          "ranged_range": {
            "type": "object",
            "description": "Ranged range properties",
            "properties": {
              "normal": {
                "type": "number",
                "description": "Normal range in feet"
              },
              "long": {
                "type": "number",
                "description": "Long range in feet"
              }
            }
          },
          "area_of_effect": {
            "type": "object",
            "description": "Area of effect properties",
            "properties": {
              "shape": {
                "type": "string",
                "description": "Shape of area (e.g., 'Cone', 'Cylinder', 'Line', 'Emanation', 'Sphere')"
              },
              "size": {
                "type": "string",
                "description": "Size of area (e.g., '30-foot radius', '60-foot radius')"
              }
            }
          }
        }
      },
      "duration": {
        "type": "string",
        "description": "Duration of the item's effects (e.g., '1 minute', '1 hour', '7 days', 'until next dawn')"
      },
      "curse": {
        "type": "object",
        "description": "Curse properties of the item",
        "properties": {
          "description": {
            "type": "string",
            "description": "Description of the curse"
          },
          "removal": {
            "type": "string",
            "description": "How to remove the curse (e.g., 'Remove Curse spell')"
          }
        }
      },
      "sentience": {
        "type": "object",
        "description": "Sentience properties of the item",
        "properties": {
          "alignment": {
            "type": "string",
            "description": "Item's alignment (e.g., 'Chaotic Evil', 'Lawful Neutral', 'Neutral')"
          },
          "intelligence": {
            "type": "number",
            "description": "Item's Intelligence score"
          },
          "wisdom": {
            "type": "number",
            "description": "Item's Wisdom score"
          },
          "charisma": {
            "type": "number",
            "description": "Item's Charisma score"
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Languages the item can speak"
          },
          "darkvision": {
            "type": "number",
            "description": "Darkvision range in feet"
          },
          "personality": {
            "type": "string",
            "description": "Item's personality description"
          },
          "purpose": {
            "type": "string",
            "description": "Item's purpose or goal"
          },
          "communication": {
            "type": "string",
            "description": "How the item communicates (e.g., 'telepathically')"
          }
        }
      },
      "artifact_properties": {
        "type": "object",
        "description": "Special properties unique to artifacts",
        "properties": {
          "random_beneficial_properties": {
            "type": "object",
            "description": "Random beneficial properties",
            "properties": {
              "minor_count": {
                "type": "number",
                "description": "Number of minor beneficial properties"
              },
              "major_count": {
                "type": "number",
                "description": "Number of major beneficial properties"
              }
            }
          },
          "random_detrimental_properties": {
            "type": "object",
            "description": "Random detrimental properties",
            "properties": {
              "minor_count": {
                "type": "number",
                "description": "Number of minor detrimental properties"
              },
              "major_count": {
                "type": "number",
                "description": "Number of major detrimental properties"
              }
            }
          },
          "destroy_conditions": {
            "type": "string",
            "description": "Conditions required to destroy the artifact"
          }
        }
      },
      "spell_scroll_details": {
        "type": "object",
        "description": "Spell scroll specific details",
        "properties": {
          "spell_level": {
            "type": "number",
            "description": "Level of the spell on the scroll"
          },
          "spell_name": {
            "type": "string",
            "description": "Name of the spell on the scroll"
          },
          "save_dc": {
            "type": "number",
            "description": "Save DC for the spell"
          },
          "attack_bonus": {
            "type": "number",
            "description": "Attack bonus for the spell"
          }
        }
      },
      "protection_type": {
        "type": "string",
        "description": "Type of creature the item protects against (for protection items)"
      },
      "special_effects": {
        "type": "array",
        "items": {
          "type": "object",
          "description": "Special effects of the item",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the special effect"
            },
            "description": {
              "type": "string",
              "description": "Description of the effect"
            }
          }
        },
        "description": "Special effects of the item"
      },
      "light_properties": {
        "type": "object",
        "description": "Light emission properties",
        "properties": {
          "bright_light_radius": {
            "type": "number",
            "description": "Bright light radius in feet"
          },
          "dim_light_radius": {
            "type": "number",
            "description": "Dim light radius in feet"
          },
          "light_type": {
            "type": "string",
            "description": "Type of light (e.g., 'sunlight', 'harmless')"
          }
        }
      },
      "speed": {
        "type": "object",
        "description": "Movement speed properties",
        "properties": {
          "fly_speed": {
            "type": "number",
            "description": "Fly speed in feet"
          },
          "climb_speed": {
            "type": "number",
            "description": "Climb speed in feet"
          },
          "swim_speed": {
            "type": "number",
            "description": "Swim speed in feet"
          }
        }
      },
      "weight_capacity": {
        "type": "number",
        "description": "Maximum weight the item can carry in pounds"
      },
      "hit_points": {
        "type": "number",
        "description": "Hit Points of the item"
      },
      "armor_class": {
        "type": "number",
        "description": "Armor Class of the item"
      },
      "healing_properties": {
        "type": "object",
        "description": "Healing properties of the item",
        "properties": {
          "hit_points_regained": {
            "type": "string",
            "description": "Hit Points regained (e.g., '1 Hit Point Die', '1 Hit Point every 5 minutes')"
          },
          "spell_level": {
            "type": "number",
            "description": "Spell level for healing (e.g., '1 charge per spell level, maximum 4')"
          }
        }
      },
      "temporary_hit_points": {
        "type": "object",
        "description": "Temporary Hit Points granted by the item",
        "properties": {
          "amount": {
            "type": "string",
            "description": "Amount of temporary hit points"
          },
          "duration": {
            "type": "string",
            "description": "Duration of temporary hit points"
          }
        }
      },
      "exhaustion": {
        "type": "object",
        "description": "Exhaustion properties",
        "properties": {
          "levels": {
            "type": "number",
            "description": "Number of exhaustion levels gained"
          }
        }
      },
      "table_effects": {
        "type": "array",
        "items": {
          "type": "object",
          "description": "Table-based effects for random items",
          "properties": {
            "roll_range": {
              "type": "string",
              "description": "Roll range (e.g., '01-20', '21-25')"
            },
            "effect": {
              "type": "string",
              "description": "Effect that occurs on this roll"
            }
          }
        },
        "description": "Table effects for random item results"
      },
      "item_slot_requirements": {
        "type": "object",
        "description": "Equipment slot requirements",
        "properties": {
          "slot": {
            "type": "string",
            "description": "Equipment slot (e.g., 'hands', 'waist', 'neck', 'worn')"
          },
          "size": {
            "type": "string",
            "description": "Size requirement (e.g., 'Tiny', 'Medium', 'Large')"
          }
        }
      }
    }
  }
}
