{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Monsters Schema (2024 Rules)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the monster"
      },
      "name": {
        "type": "string",
        "description": "Full name of the monster"
      },
      "size": {
        "type": "string",
        "description": "Size of the monster",
        "enum": ["Tiny", "Small", "Medium", "Large", "Huge", "Gargantuan"]
      },
      "type": {
        "type": "string",
        "description": "Type of the monster"
      },
      "subtype": {
        "type": "string",
        "description": "Subtype of the monster"
      },
      "alignment": {
        "type": "string",
        "description": "Alignment of the monster"
      },
      "initiative": {
        "type": "integer",
        "description": "Initiative modifier of the monster"
      },
      "initiative_details": {
        "type": "string",
        "description": "Full initiative display (e.g., '+4 (14)')"
      },
      "armor_class": {
        "type": "integer",
        "description": "Armor class of the monster"
      },
      "armor_class_details": {
        "type": "string",
        "description": "Details about armor class calculation"
      },
      "armor_class_options": {
        "type": "array",
        "description": "Options for armor class"
      },
      "hit_points": {
        "type": "integer",
        "description": "Hit points of the monster"
      },
      "hit_dice": {
        "type": "string",
        "description": "Hit dice notation"
      },
      "speed": {
        "type": "object",
        "description": "Speed values for the monster",
        "properties": {
          "walk": {"type": "string"},
          "fly": {"type": "string"},
          "swim": {"type": "string"},
          "climb": {"type": "string"},
          "burrow": {"type": "string"},
          "other": {"type": "array"}
        }
      },
      "ability_scores": {
        "type": "object",
        "description": "Ability scores of the monster",
        "properties": {
          "str": {"type": "integer"},
          "dex": {"type": "integer"},
          "con": {"type": "integer"},
          "int": {"type": "integer"},
          "wis": {"type": "integer"},
          "cha": {"type": "integer"}
        }
      },
      "ability_score_modifiers": {
        "type": "object",
        "description": "Ability score modifiers of the monster",
        "properties": {
          "str": {"type": "integer"},
          "dex": {"type": "integer"},
          "con": {"type": "integer"},
          "int": {"type": "integer"},
          "wis": {"type": "integer"},
          "cha": {"type": "integer"}
        }
      },
      "saving_throws": {
        "type": "object",
        "description": "Saving throw proficiencies",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "modifier": {"type": "integer"},
            "bonus": {"type": "integer"}
          }
        }
      },
      "skills": {
        "type": "object",
        "description": "Skill proficiencies",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "modifier": {"type": "integer"},
            "bonus": {"type": "integer"}
          }
        }
      },
      "senses": {
        "type": "object",
        "description": "Senses of the monster",
        "properties": {
          "darkvision": {"type": "integer"},
          "blindsight": {"type": "integer"},
          "truesight": {"type": "integer"},
          "tremorsense": {"type": "integer"},
          "passive_perception": {"type": "integer"}
        }
      },
      "languages": {
        "type": "string",
        "description": "Languages the monster speaks"
      },
      "challenge_rating": {
        "type": "string",
        "description": "Challenge rating of the monster"
      },
      "xp": {
        "type": "integer",
        "description": "Experience points value"
      },
      "proficiency_bonus": {
        "type": "integer",
        "description": "Monster's proficiency bonus"
      },
      "actions": {
        "type": "array",
        "description": "List of actions the monster can take",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "attack_bonus": {"type": "integer"},
            "damage": {"type": "string"},
            "damage_dice": {"type": "string"},
            "damage_bonus": {"type": "integer"},
            "save_dc": {"type": "integer"},
            "save_type": {"type": "string"},
            "save_effect": {"type": "string"},
            "range": {"type": "string"},
            "reach": {"type": "string"},
            "recharge": {"type": "string"}
          }
        }
      },
      "bonus_actions": {
        "type": "array",
        "description": "Bonus actions available",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "save_dc": {"type": "integer"},
            "save_type": {"type": "string"}
          }
        }
      },
      "reactions": {
        "type": "array",
        "description": "Reactions available",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "trigger": {"type": "string"},
            "description": {"type": "string"}
          }
        }
      },
      "legendary_actions": {
        "type": "array",
        "description": "Legendary actions",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "uses": {"type": "integer"},
            "recharge": {"type": "boolean"}
          }
        }
      },
      "lair_actions": {
        "type": "array",
        "description": "Lair actions",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"},
            "save_dc": {"type": "integer"}
          }
        }
      },
      "traits": {
        "type": "array",
        "description": "Special traits of the monster",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "description": {"type": "string"}
          }
        }
      },
      "book": {
        "type": "string",
        "description": "Source book"
      },
      "page": {
        "type": "integer",
        "description": "Page number"
      },
      "legendary_resistance": {
        "type": "integer",
        "description": "Number of legendary resistance uses (2024 rules)"
      },
      "immunities": {
        "type": "array",
        "description": "Damage and condition immunities (2024 rules)",
        "items": {"type": "string"}
      },
      "vulnerabilities": {
        "type": "array",
        "description": "Damage vulnerabilities (2024 rules)",
        "items": {"type": "string"}
      },
      "resistances": {
        "type": "array",
        "description": "Damage resistances (2024 rules)",
        "items": {"type": "string"}
      },
      "equipment": {
        "type": "array",
        "description": "Equipment or gear the monster carries",
        "items": {"type": "string"}
      },
      "habitat": {
        "type": "string",
        "description": "Habitat or environment"
      },
      "treasure": {
        "type": "string",
        "description": "Treasure type"
      },
      "artist": {
        "type": "string",
        "description": "Artist who created the monster art"
      }
    },
    "additionalProperties": true
  }
}
