{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Monster Types Schema (2024 Rules)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the type"
      },
      "name": {
        "type": "string",
        "description": "Full name of the type"
      },
      "book": {
        "type": "string",
        "description": "Source book for the type"
      },
      "desc": {
        "type": "string",
        "description": "Description of the type"
      },
      "monsters": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of monsters that belong to this type"
      },
      "page": {
        "type": "integer",
        "description": "Page number in source book"
      },
      "trait_modifiers": {
        "type": "array",
        "description": "Trait modifiers applied to creatures of this subtype (2024 rules)"
      }
    }
  }
}
