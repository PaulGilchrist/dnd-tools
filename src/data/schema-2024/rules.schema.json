{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rules Schema (2024 Rules)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name", "desc"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the rule"
      },
      "name": {
        "type": "string",
        "description": "Full name of the rule"
      },
      "desc": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Description of the rule (updated for 2024 rules)"
      },
      "category": {
        "type": "string",
        "description": "Category of rule (combat, exploration, social)"
      },
      "page_reference": {
        "type": "integer",
        "description": "Page number in source book"
      },
      "revision_notes": {
        "type": "string",
        "description": "Notes about changes from 5e to 2024 rules"
      }
    }
  }
}
