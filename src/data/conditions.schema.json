{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Conditions Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name", "desc"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the condition"
      },
      "name": {
        "type": "string",
        "description": "Full name of the condition"
      },
      "desc": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Array of description points for the condition"
      }
    }
  }
}
