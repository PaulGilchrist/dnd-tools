{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Races Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the race"
      },
      "name": {
        "type": "string",
        "description": "Full name of the race"
      },
      "type": {
        "type": "string",
        "description": "Type of race entry"
      },
      "family_type": {
        "type": "string",
        "description": "Type of family structure"
      },
      "lists": {
        "type": "object",
        "description": "Name lists for the race"
      },
      "speed": {
        "type": "integer",
        "description": "Base walking speed"
      },
      "ability_bonuses": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "ability_score": {
              "type": "string"
            },
            "bonus": {
              "type": "integer"
            }
          }
        },
        "description": "Ability score bonuses"
      },
      "ability_bonus_options": {
        "type": "object",
        "description": "Options for ability bonus selection"
      },
      "alignment": {
        "type": "string",
        "description": "Typical alignment of the race"
      },
      "age": {
        "type": "string",
        "description": "Aging information"
      },
      "size": {
        "type": "string",
        "description": "Size category"
      },
      "size_description": {
        "type": "string",
        "description": "Description of size"
      },
      "starting_proficiencies": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Starting proficiencies"
      },
      "starting_proficiency_options": {
        "type": "object",
        "description": "Options for starting proficiencies"
      },
      "languages": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Languages spoken"
      },
      "language_desc": {
        "type": "string",
        "description": "Description of languages"
      },
      "language_options": {
        "type": "object",
        "description": "Options for additional languages"
      },
      "traits": {
        "type": "array",
        "items": {
          "type": "object",
          "description": "Racial traits"
        },
        "description": "Array of racial traits"
      },
      "subraces": {
        "type": "array",
        "items": {
          "type": "object",
          "description": "Subrace information"
        },
        "description": "Array of subraces"
      },
      "book": {
        "type": "string",
        "description": "Source book"
      },
      "desc": {
        "type": "string",
        "description": "General description"
      },
      "page": {
        "type": "integer",
        "description": "Page number"
      }
    }
  }
}
