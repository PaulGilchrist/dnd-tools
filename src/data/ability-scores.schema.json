{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ability Scores Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name", "full_name", "desc"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the ability score"
      },
      "name": {
        "type": "string",
        "description": "Abbreviated name (e.g., STR, DEX)"
      },
      "full_name": {
        "type": "string",
        "description": "Full name of the ability score"
      },
      "desc": {
        "type": "string",
        "description": "Detailed description of the ability score"
      },
      "skills": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of skills associated with this ability score"
      }
    }
  }
}
