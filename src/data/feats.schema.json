{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feats Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name", "desc"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the feat"
      },
      "name": {
        "type": "string",
        "description": "Full name of the feat"
      },
      "desc": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Description of the feat benefits"
      },
      "benefits": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of benefits from the feat"
      },
      "prerequisite": {
        "type": "string",
        "description": "Prerequisites for taking the feat"
      }
    }
  }
}
