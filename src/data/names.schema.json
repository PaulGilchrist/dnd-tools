{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Names Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the name list"
      },
      "name": {
        "type": "string",
        "description": "Full name of the name list"
      },
      "type": {
        "type": "string",
        "description": "Type of name list (race, building, etc.)"
      },
      "family_type": {
        "type": "string",
        "description": "Type of family structure"
      },
      "lists": {
        "type": "object",
        "properties": {
          "females": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of female names"
          },
          "males": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of male names"
          },
          "family": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of family names"
          },
          "first": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of first names"
          },
          "second": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of second names"
          }
        }
      }
    }
  }
}
