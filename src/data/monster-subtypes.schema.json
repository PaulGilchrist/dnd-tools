{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Monster Subtypes Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the subtype"
      },
      "name": {
        "type": "string",
        "description": "Full name of the subtype"
      },
      "book": {
        "type": "string",
        "description": "Source book for the subtype"
      },
      "desc": {
        "type": "string",
        "description": "Description of the subtype"
      },
      "monsters": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of monsters that belong to this subtype"
      },
      "page": {
        "type": "integer",
        "description": "Page number in source book"
      }
    }
  }
}
