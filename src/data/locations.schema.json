{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Locations Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the location"
      },
      "name": {
        "type": "string",
        "description": "Full name of the location"
      },
      "book": {
        "type": "string",
        "description": "Source book for the location"
      },
      "desc": {
        "type": "string",
        "description": "Description of the location"
      },
      "image": {
        "type": "string",
        "description": "Image filename for the location"
      },
      "page": {
        "type": "integer",
        "description": "Page number in source book"
      },
      "parent": {
        "type": "string",
        "description": "Parent location if applicable"
      },
      "type": {
        "type": "string",
        "description": "Type of location (city, town, keep, continent, world, area)"
      }
    }
  }
}
