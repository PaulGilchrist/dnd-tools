{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Classes Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["index", "name"],
    "properties": {
      "index": {
        "type": "string",
        "description": "Short identifier for the class"
      },
      "name": {
        "type": "string",
        "description": "Full name of the class"
      },
      "hit_die": {
        "type": "integer",
        "description": "Number of dice for hit points per level"
      },
      "proficiency_choices": {
        "type": "array",
        "description": "Array of proficiency choices"
      },
      "proficiencies": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of proficiencies granted by the class"
      },
      "saving_throws": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of saving throw proficiencies"
      },
      "class_levels": {
        "type": "array",
        "description": "Array of class level data"
      },
      "subclasses": {
        "type": "array",
        "description": "Array of available subclasses"
      },
      "spellcasting": {
        "type": "object",
        "description": "Spellcasting information for the class"
      }
    }
  }
}
