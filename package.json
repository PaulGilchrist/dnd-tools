{
  "authors": [
    "Paul Gilchrist"
  ],
  "name": "dnd-tools",
  "description": "Quick reference tools for Dungeons & Dragons 5th Edition",
  "license": "MIT",
  "version": "1.0.0",
  "scripts": {
    "build": "ng build --configuration production --base-href /dnd-tools/",
    "deploy": "ng deploy dnd-tools --base-href=/dnd-tools/",
    "lint": "npx ng lint dnd-tools",
    "ng": "ng",
    "predeploy": "npm run build",
    "start": "ng serve",
    "test": "ng test",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "lodash": "^4.18.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.2.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.5",
    "@angular/animations": "^21.2.6",
    "@angular/cli": "^21.2.5",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@types/jasmine": "^6.0.0",
    "@types/lodash": "^4.14.202",
    "@types/node": "^25.5.0",
    "@types/showdown": "^2.0.6",
    "angular-cli-ghpages": "^3.0.2",
    "gh-pages": "^6.3.0",
    "jasmine-core": "^6.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "showdown": "^2.1.0",
    "typescript": "~5.9.3"
  }
}
